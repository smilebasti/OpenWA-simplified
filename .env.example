# =============================================================================
# OpenWA - Environment Configuration
# =============================================================================
# Copy this file to .env and customize as needed.

# =============================================================================
# CORE SETTINGS
# =============================================================================
NODE_ENV=production
API_PORT=2785
DASHBOARD_PORT=2886
LOG_LEVEL=info                      # error | warn | info | debug

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# =============================================================================
# SECURITY
# =============================================================================
# Master API key - leave empty to disable, set to a secure random value in prod
API_MASTER_KEY=

# =============================================================================
# ENGINE
# =============================================================================
SESSION_DATA_PATH=./data/sessions
PUPPETEER_HEADLESS=true
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage,--disable-gpu

# =============================================================================
# DATABASE (SQLite only)
# =============================================================================
DATABASE_NAME=./data/openwa.sqlite
DATABASE_LOGGING=false

# =============================================================================
# STORAGE (local filesystem only)
# =============================================================================
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/media

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_TTL=60                   # Time window in seconds
RATE_LIMIT_MAX=100                  # Max requests per window

# =============================================================================
# DOCKER COMPOSE IMAGE OVERRIDES (optional)
# =============================================================================
# OPENWA_API_IMAGE=smilebasti/openwa-api:v1.0.0
# OPENWA_DASH_IMAGE=smilebasti/openwa-dashboard:v1.0.0
